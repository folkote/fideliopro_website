# FidelioPro FastAPI Configuration
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# Application settings
APP_NAME=FidelioPro FastAPI
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=80

# DaData API credentials
DADATA_TOKEN=ec77bce523c6d55c59fc5212a52fdd61b4a27b73
DADATA_SECRET=3b74208e4761b8fb21af0abe906519d3db1862fc

# Geolocation settings
GEOLOCATION_ENABLED=true
GEOLOCATION_SERVICE_URL=http://ip-api.com/json/{ip}?fields=status,country,city,isp
GEOLOCATION_TIMEOUT=5.0
GEOLOCATION_FALLBACK_SERVICE=https://ipapi.co/{ip}/json/

# Cache settings
CACHE_ENABLED=true
CACHE_TYPE=postgres
CACHE_TTL=3600
CACHE_DIR=cache
DATABASE_URL=postgresql+psycopg://postgres:7969900@10.0.0.8:5432/fidelio_address_api
CACHE_DB_SCHEMA=fideliopro
CACHE_DB_TABLE=cache_entries

# Redis settings (optional, for Redis cache backend)
# REDIS_URL=redis://localhost:6379/0

# Logging settings
LOG_LEVEL=INFO
LOG_FILE=logs/webserver.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Static files
STATIC_DIR=static
WEBSITE_DIR=static/website
SQL_DIR=static/sql

# Security
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=["*"]
