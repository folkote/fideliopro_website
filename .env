# FidelioPro FastAPI Configuration

# Application settings
APP_NAME=FidelioPro FastAPI
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=7080

# DaData API credentials (replace with your actual credentials)
DADATA_TOKEN=ec77bce523c6d55c59fc5212a52fdd61b4a27b73
DADATA_SECRET=3b74208e4761b8fb21af0abe906519d3db1862fc

# Geolocation settings
GEOLOCATION_ENABLED=true
GEOLOCATION_SERVICE_URL=http://ip-api.com/json/{ip}?fields=status,country,city,isp
GEOLOCATION_TIMEOUT=5.0
GEOLOCATION_FALLBACK_SERVICE=https://ipapi.co/{ip}/json/

# Cache settings
CACHE_ENABLED=true
CACHE_TYPE=file
CACHE_TTL=3600
CACHE_DIR=cache

# Redis settings (optional, for Redis cache)
# REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Logging settings
LOG_LEVEL=INFO
LOG_FILE=logs/webserver.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# Rate limiting settings
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Static files settings
STATIC_DIR=static
WEBSITE_DIR=static/website
SQL_DIR=static/sql

# Security settings
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=["*"]